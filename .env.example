# WarEra API — optional key (anonymous mode works without it, limit 100/window)
# Add your key to increase API rate limits.
WARERA_API_KEY=

# WarEra API base URL (default: https://api2.warera.io/trpc)
WARERA_BASE_URL=https://api2.warera.io/trpc

# Target entities (optional — resolved by name search by default)
# The Federation
WARERA_ALLIANCE_NAME=The Federation
# WARERA_ALLIANCE_ID=6a29697ef0f195d344d6869c

# Justice
WARERA_NAME=Justice
# Pinned by default in wareraService.ts. Override only if the target MU changes.
# WARERA_MU_ID=687633b772c4886cc6fa3d56
