# WarEra API — optional key (anonymous mode works without it, limit 100/window)
# Add your key to increase API rate limits (→ 500/window).
#
# ⚠️ In production (Coolify / Docker / Nuxt), env vars must be prefixed with
#    NUXT_ so Nuxt's runtimeConfig picks them up at RUNTIME (not build time):
#      NUXT_WARERA_API_KEY=xxx
#      NUXT_WARERA_BASE_URL=https://api2.warera.io/trpc
#    The bare WARERA_API_KEY only works in `nuxt dev` (via .env file).
NUXT_WARERA_API_KEY=

# WarEra API base URL (default: https://api2.warera.io/trpc)
NUXT_WARERA_BASE_URL=https://api2.warera.io/trpc

# Optional MySQL tracker store. When set, the server persists WarEra battles,
# rankings, entity snapshots, and sync checkpoints here. Use the NUXT_ prefix
# in production so Nuxt runtimeConfig can read it without rebuilding.
# Example: mysql://user:password@mysql:3306/warera
NUXT_DATABASE_URL=
PORT=3000

# Target entities (optional — resolved by name search by default)
# The Federation
WARERA_ALLIANCE_NAME=The Federation
# WARERA_ALLIANCE_ID=6a29697ef0f195d344d6869c

# Justice
WARERA_NAME=Justice
# Pinned by default in wareraService.ts. Override only if the target MU changes.
# WARERA_MU_ID=687633b772c4886cc6fa3d56

# Extra MUs to force-include in the Federation "DMG per military unit" ranking
# even if their founding country is not an alliance member or pagination misses
# them. Comma-separated. Defaults to both "Justice" MUs (Sweden + Philippines).
# WARERA_FED_EXTRA_MU_IDS=687633b772c4886cc6fa3d56,698ca55790b70ac76de933c5
